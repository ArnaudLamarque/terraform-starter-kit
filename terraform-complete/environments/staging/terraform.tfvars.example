project        = "myapp"
aws_region     = "eu-west-1"
aws_account_id = "123456789012"
github_org     = "my-github-org"
github_repo    = "my-repo"
domain_name    = "myapp.com"
alert_emails   = ["ops@myapp.com"]

# App secrets — never commit the real values
app_secrets = {
  stripe-key = {
    value       = "sk_test_..."
    description = "Stripe API key"
  }
}
